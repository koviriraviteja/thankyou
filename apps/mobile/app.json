{
  "expo": {
    "name": "ThankU",
    "slug": "thanku",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#5ED6E3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thanku.app"
    },
    "android": {
      "package": "com.thanku.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#5ED6E3"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "scheme": "thanku",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker",
      "expo-location"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a8c65f4b-8531-4fc1-a2f3-377035f3b8a9"
      }
    }
  }
}
