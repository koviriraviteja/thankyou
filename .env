# Database
DATABASE_URL="postgresql://olx_user:olx_pass@localhost:5432/olx_clone"
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL="redis://localhost:6379"

# Elasticsearch
ELASTICSEARCH_HOST="http://localhost:9200"
ELASTICSEARCH_USER="elastic"
ELASTICSEARCH_PASS="changeme"

# MongoDB (Chat)
MONGODB_URI="mongodb://olx_user:olx_pass@localhost:27017/olx_clone_chat?authSource=admin"

# JWT
JWT_SECRET="your-secret-key-min-32-chars-long"
JWT_REFRESH_SECRET="your-refresh-secret-key-long"
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# MSG91 (OTP)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_ROUTE_ID="your-route-id"

# Razorpay (Payments)
RAZORPAY_KEY_ID="rzp_test_xxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="webhook-secret-from-dashboard"

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="olx-clone"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_CDN_URL="https://cdn.yourapp.com"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSy..."
GOOGLE_MAPS_API_KEY="AIzaSy..." # Server-side

# Firebase (Push notifications)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@...iam.gserviceaccount.com"

# Resend (Email)
RESEND_API_KEY="re_xxx..."

# Services URLs
AUTH_SERVICE_URL="http://localhost:3001"
LISTINGS_SERVICE_URL="http://localhost:3002"
SEARCH_SERVICE_URL="http://localhost:3003"
CHAT_SERVICE_URL="http://localhost:3004"
PAYMENT_SERVICE_URL="http://localhost:3005"
MEDIA_SERVICE_URL="http://localhost:3006"
NOTIFICATION_SERVICE_URL="http://localhost:3007"
USERS_SERVICE_URL="http://localhost:3008"

# Public URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_MOBILE_DEEP_LINK="olx://localhost"

# Node environment
NODE_ENV="development"

# Expo (Mobile)
EXPO_PUBLIC_API_URL="http://localhost:3000/api"
EXPO_PUBLIC_WEB_URL="http://localhost:3000"
